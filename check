#!/usr/bin/env bash
# The single verification command. CI runs exactly this, so a green local run means a green build
# rather than a guess about one. Ordered cheapest-first: a style slip should fail in seconds, not
# after a full Gradle build.
#
#   ./check          everything
#   ./check --fast   skip the build and the demo canary — for the edit loop, not for a push
set -euo pipefail
cd "$(dirname "$0")"

FAST=0
if [ "${1:-}" = "--fast" ]; then
    FAST=1
elif [ -n "${1:-}" ]; then
    echo "usage: ./check [--fast]" >&2
    exit 64
fi

# The android module needs an SDK. Falling back to the conventional location turns a cryptic
# Gradle failure into a working run on a normally-configured machine.
if [ -z "${ANDROID_HOME:-}" ] && [ -d "$HOME/Android/Sdk" ]; then
    export ANDROID_HOME="$HOME/Android/Sdk"
fi

step() { printf '\n\033[1m==> %s\033[0m\n' "$1"; }

step "ktlint"
./gradlew ktlintCheck --quiet

step "conventions"
python3 scripts/checks/check_conventions.py

step "doc caps"
python3 scripts/github-workflows/check_doc_caps.py

step "script self-tests"
# Unguarded, a regression in a release script surfaces only as a release check that silently passes.
for dir in scripts/checks scripts/github-workflows; do
    for t in "$dir"/test_*.py; do
        python3 "$t" >/dev/null 2>&1 || { python3 "$t"; exit 1; }
    done
done
echo "all script self-tests pass"

if [ "$FAST" = 1 ]; then
    printf '\n\033[1m--fast: skipped build and demo canary\033[0m\n'
    exit 0
fi

step "build (compile, test, apiCheck)"
./gradlew build

step "demo canary"
# demo/ is a separate composite build that `./gradlew build` never compiles, so this is the only
# in-tree consumer compiling the way an external one does. It has no wrapper — it borrows the root.
(cd demo && ../gradlew compileKotlin --quiet)

printf '\n\033[1;32mAll checks passed.\033[0m\n'
